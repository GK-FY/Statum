{
  "name": "fy-whatsapp-bot-node",
  "version": "1.0.1",
  "description": "FY'S Airtime Bot \u2014 Standalone Node (no DB), instant QR in console + web + admin WhatsApp control",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "health": "node -e \"fetch('http://localhost:'+(process.env.PORT||5000)+'/health').then(r=>r.text()).then(console.log)\""
  },
  "dependencies": {
    "axios": "^1.18.1",
    "body-parser": "^1.20.5",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "whatsapp-web.js": "^1.34.7"
  },
  "engines": {
    "node": ">=18 <=22"
  }
}